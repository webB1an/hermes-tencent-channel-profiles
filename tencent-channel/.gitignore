media/

# Session 文件 + jsonl 日志
sessions/

# Cron 输出
cron/output/

# 日志
logs/

# 运行时状态（bot 进程产生）
state/
state.db
state.db-shm
state.db-wal
wallpaper_state.json
wallhaven_state.json
models_dev_cache.json
processes.json
feishu_seen_message_ids.json
channel_directory.json
.skills_prompt_snapshot.json

# Python 缓存
scripts/__pycache__/
*.pyc
*.pyo

